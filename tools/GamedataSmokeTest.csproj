<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <!-- Match TargetFramework to the CounterStrikeSharp.API you built/reference.
         Upstream main is on net10.0; older forks are net8.0. Set accordingly. -->
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>GamedataSmokeTest</RootNamespace>
    <AssemblyName>GamedataSmokeTest</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <!-- Option A (recommended): reference the NuGet package, version-matched to
         the CSS you deploy. -->
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.*" />
    <!-- Option B: reference the DLL you just built instead of the package:
    <Reference Include="CounterStrikeSharp.API">
      <HintPath>../../dist/addons/counterstrikesharp/api/CounterStrikeSharp.API.dll</HintPath>
    </Reference>
    -->
  </ItemGroup>
</Project>
